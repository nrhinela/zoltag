# Environment Configuration

# Copy this to .env and fill in your values

# Application
DEBUG=false
WORKER_MODE=false

# Google Cloud Platform
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Cloud Storage
STORAGE_BUCKET_NAME=zoltag-images
THUMBNAIL_BUCKET_NAME=zoltag-thumbnails

# Database (Cloud SQL)
DATABASE_URL=postgresql://user:password@/dbname?host=/cloudsql/project:region:instance
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10
DB_POOL_USE_LIFO=true
DB_KEEPALIVES=1
DB_KEEPALIVES_IDLE=30
DB_KEEPALIVES_INTERVAL=10
DB_KEEPALIVES_COUNT=5

# Worker-only DB safety rails (active when WORKER_MODE=true)
WORKER_DB_STATEMENT_TIMEOUT_MS=45000
WORKER_DB_LOCK_TIMEOUT_MS=3000
WORKER_DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=15000

# Cloud Tasks
TASK_QUEUE_NAME=image-processing
TASK_LOCATION=us-central1

# Processing Settings
THUMBNAIL_SIZE=320
BATCH_SIZE=10
MAX_WORKERS=4

# Model Configuration
FACE_DETECTION_MODEL=hog
EMBEDDING_MODEL=clip-vit-base-patch32

# API Settings
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
